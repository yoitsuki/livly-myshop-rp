rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isAdmin() {
      return request.auth != null
          && request.auth.uid == 'zXleLmp8W8OwUH2j7EIg7BNyLXs2';
    }

    match /items/{itemId}/{file} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // viewer から admin への画像受け渡し用 inbox。
    // 公開の create + read を許可し、上書き / 削除は admin のみ。
    // 一覧 (listAll) は read が list を兼ねるので true で OK。
    match /inbox/{file=**} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin();
    }
  }
}
