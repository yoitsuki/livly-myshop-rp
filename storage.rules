rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isAdmin() {
      return request.auth != null
          && request.auth.uid == 'zXleLmp8W8OwUH2j7EIg7BNyLXs2';
    }

    match /items/{itemId}/{file} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
